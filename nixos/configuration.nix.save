#Edit this configuration file to define what should be installed on
# your system.  Help is available in the configuration.nix(5) man page
# and in the NixOS manual (accessible by running ‘nixos-help’).
{ config, pkgs, lib, inputs, ... }:
{

nix.settings.experimental-features = [ "nix-command" "flakes" ];
nix.settings.download-buffer-size = 67108864;
#security.sudo.enable = true;
#security.sudo.configFile = "/etc/sudoers";  # This is usually the default
#security.sudo.extraRules = ''
#  %wheel ALL=(ALL:ALL) SETENV: ALL
#'';
sops.secrets."syncthing-gui-password" = {
  sopsFile = ./secrets/secrets.yaml;   # path to your encrypted secrets.yaml
  owner = "mike";                      # user that will read it
};



  imports =
    [ # Include the results of the hardware scan.
      ./hardware-configuration.nix
#      ./modules/syncthing.nix
#    inputs.home-manager.nixosModules.default
    ];

  # Bootloader.
  boot.loader.systemd-boot.enable = true;
  boot.loader.efi.canTouchEfiVariables = true;

  #networking.hostName = "nixos"; # Define your hostname.
  # networking.wireless.enable = true;  # Enables wireless support via wpa_supplicant.

  # Configure network proxy if necessary
  # networking.proxy.default = "http://user:password@proxy:port/";
  # networking.proxy.noProxy = "127.0.0.1,localhost,internal.domain";

  # Enable networking
networking = {
  networkmanager.enable = true;

  interfaces.enp0s25.ipv4.addresses = [
    {
      address = "192.168.79.80";
      prefixLength = 24;
    }
  ];

  defaultGateway = "192.168.79.1";
  nameservers = [
    "1.1.1.1"
    "8.8.8.8"
  ];
  hostId = "deadb33f";
  hostName = "nixos";
  domain = "local";

  hosts = {
    "127.0.0.1" = [ "localhost" ];
    "127.0.0.2" = [ "nixos" ];
    "192.168.79.72" = [ "nixos-server" ];
  };
};

  services.avahi = {
    enable = true;

    publish = {
      enable = true;
      addresses = true;
      domain = true;
      hinfo = true;
      userServices = true;
      workstation = true;
    };
    nssmdns4 = true;
    openFirewall = true;
  };

  services.resolved = {
    enable = true;
    fallbackDns = [
      "8.8.8.8"
      "2001:4860:4860::8844"
    ];
    extraConfig = ''
      MulticastDNS=yes
    '';
  };


  # Set your time zone.
  time.timeZone = "Pacific/Honolulu";

  # Select internationalisation properties.
  i18n.defaultLocale = "en_US.UTF-8";

  i18n.extraLocaleSettings = {
    LC_ADDRESS = "en_US.UTF-8";
    LC_IDENTIFICATION = "en_US.UTF-8";
    LC_MEASUREMENT = "en_US.UTF-8";
    LC_MONETARY = "en_US.UTF-8";
    LC_NAME = "en_US.UTF-8";
    LC_NUMERIC = "en_US.UTF-8";
    LC_PAPER = "en_US.UTF-8";
    LC_TELEPHONE = "en_US.UTF-8";
    LC_TIME = "en_US.UTF-8";
  };

  # Enable the X11 windowing system.
  # You can disable this if you're only using the Wayland session.
  services.xserver.enable = true;

  # Enable the KDE Plasma Desktop Environment.
  services.displayManager.sddm.enable = true;
  services.desktopManager.plasma6.enable = true;

  # Configure keymap in X11
  services.xserver.xkb = {
    layout = "us";
    variant = "";
  };

  # Enable CUPS to print documents.
  boot.kernelModules = [ "sg" ];
  services.printing.enable = true;
  services.printing.drivers = [
    pkgs.brlaser
    pkgs.brgenml1lpr
    pkgs.brgenml1cupswrapper
  ];

  hardware.sane.enable = true;
  services.teamviewer.enable = true;
  #enable flatpak
  services.flatpak.enable = true;
   systemd.services.flatpak-repo = {
    wantedBy = [ "multi-user.target" ];
    path = [ pkgs.flatpak ];
    script = ''
      flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo
    '';
  };
  hardware.bluetooth.enable = true;




  # Enable sound with pipewire.
  services.pulseaudio.enable = false;
  security.rtkit.enable = true;
  services.pipewire = {
    enable = true;
    alsa.enable = true;
    alsa.support32Bit = true;
    pulse.enable = true;
    # If you want to use JACK applications, uncomment this
    #jack.enable = true;

    # use the example session manager (no others are packaged yet so this is enabled by default,
    # no need to redefine it in your config for now)
    #media-session.enable = true;
  };

  # Enable touchpad support (enabled default in most desktopManager).
  # services.xserver.libinput.enable = true;


  #services.nextcloud = {
   # enable = true;
#    hostName = "nixos";
#    database = {
#      type = "sqlite"; # or "mysql" if you prefer
#      user = "mike";
#      password = "monkeyMOMpod--"; # Change this to a secure password
#    };
#    adminUser = "admin"; # Change this to your desired admin username
#  };

 # networking.firewall.allowedTCPPorts = [ 80 443 ]; # Allow HTTP and HTTPS


  # Define a user account. Don't forget to set a password with ‘passwd’.
  users.users.mike = {
    isNormalUser = true;
    description = "Mike Lilliie";
    extraGroups = [ "networkmanager" "wheel" ];
    packages = with pkgs; [
      kdePackages.kate
    #  thunderbird
    ];
  };

  users.extraUsers.mike = {
    isNormalUser = true;
    extraGroups = [
      "networkmanager"
      "wheel"
      "adbusers"
      "scanner"
      "lp"
    ];
  };


# Install firefox.
programs.firefox.enable = true;


  programs.ssh = {
    startAgent = true;
  };

  environment.etc."ssh/ssh_config".text = ''
    Host nixos-server
      HostName 192.168.79.72
      User mike
      IdentityFile ~/.ssh/id_ed25519
      IdentitiesOnly yes
  '';

  # Optional: pin the server’s host key to avoid “unknown host” prompts
  environment.etc."ssh/known_hosts".text = ''
    nixos-server ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIINURdP5aQJxYI3h/KGPm9QjlPmJHcOr5ZClJobfuWpi mlillie57@gmail.com

  '';


  # Allow unfree packages
  nixpkgs.config.allowUnfree = true;

  # List packages installed in system profile. To search, run:
  # $ nix search wget
  environment.systemPackages = with pkgs; [
    borgbackup
    vorta
    tree
    ripgrep
    bash
    coreutils
    findutils
    gzip
    curl
    wget
    jq
   # git
    gparted
    openssl
    parted  
    util-linux
    sops
    age
    go
    syncthing
    anki-bin
    xsane
    gscan2pdf
    nmap
    openssh
    plocate
    neovim
    logseq
    certbot
#  vim # Do not forget to add an editor to edit configuration.nix! The Nano editor is also installed by default.
  #  wget
  ];

  # Some programs need SUID wrappers, can be configured further or are
  # started in user sessions.
  # programs.mtr.enable = true;
  # programs.gnupg.agent = {
  #   enable = true;
  #   enableSSHSupport = true;
  # };

  # List services that you want to enable:
   services.locate.enable = true;
  services.locate.package = pkgs.plocate;

  # Enable the OpenSSH daemon.
  services.openssh.enable = true;
  services.openssh.settings.PermitRootLogin = "prohibit-password";  # Prevent root login
  services.openssh.settings.PasswordAuthentication = false;  # Disable password authentication (optional)
  services.openssh.settings.PubkeyAuthentication = true;
  services.openssh.settings.X11Forwarding = false;  # Disable X11 forwarding
  services.openssh.settings.AllowUsers = [ "mike"];  # Specify allowed users
  # Open ports in the firewall.
    networking.firewall.allowedTCPPorts = [ 22 443 ];
    networking.firewall.allowedUDPPorts = [ 22 ];
  # Or disable the firewall altogether.
  # networking.firewall.enable = false;

  # This value determines the NixOS release from which the default
  # settings for stateful data, like file locations and database versions  # on your system were taken. It‘s perfectly fine and recommended to leave
  # this value at the release version of the first install of this system.
  # Before changing this value read the documentation for this option
  # (e.g. man configuration.nix or on https://nixos.org/nixos/options.html).
  system.stateVersion = "25.05"; # Did you read the comment?

}
